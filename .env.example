# Set ONE of these — the tool auto-detects which provider to use.
# If both are set, Anthropic is used by default; override with
# SEO_AGENT_LLM_PROVIDER=openai if you want OpenAI instead.
#
# Without either key set, the tool still runs fully — every technical,
# content, and GEO check is deterministic. You only lose the LLM-written
# executive summary and (optional) per-page content-gap analysis.

OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: force a specific provider when both keys are set above
# SEO_AGENT_LLM_PROVIDER=openai
